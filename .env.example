# ─── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=mrh_admin
DATABASE_PASSWORD=change_me_in_production
DATABASE_NAME=mrh_academy_db
# DATABASE_URL=postgresql://user:password@host:port/db

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_me_to_at_least_32_characters_in_production
JWT_EXPIRES_IN=15m

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ─── Cloudinary ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@mrh-academy.com

# ─── Admin ───────────────────────────────────────────────
ADMIN_EMAILS=admin@example.com
SUBADMIN_DEFAULT_PASSWORD=change_me_in_production

# ─── Database Migration ──────────────────────────────────
RUN_MIGRATIONS=true
CONFIRM_BOOTSTRAP=no
