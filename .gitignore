# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
.next/
build/
.turbo/

# Environment variables
.env
.env.*
!.env.example
# Block nested env files from being added explicitly (defense-in-depth)
apps/*/.env
apps/*/.env.*
apps/*/.env.render
!apps/api/.gitignore
!apps/web/.gitignore
!apps/*/.env.example

# Secrets / DB connection scripts (defense-in-depth — block re-introduction)
*-passwords.mjs
list-users.mjs
fix-passwords.mjs
check-passwords.mjs
*_audit_query.sql

# Stray lockfile copies
pnpm-lock.yaml.[0-9]*

# History cleanup artifacts
bfg-*.jar
*.bundle
replace.txt

# Generated documentation artifacts
*-report.md
*-handover.md

# IDE files
.vscode
.idea
*.swp
*.swo
*~

