# ==============================================================================
# 1. CORE APPLICATION & SERVER SETTINGS
# ==============================================================================
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
SWAGGER_ENABLED=true
PLATFORM_CURRENCY=usd

# ==============================================================================
# 2. DATABASE CONFIGURATION (PostgreSQL / Neon)
# ==============================================================================
# Primary connection URL (Neon Cloud PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:port/db?sslmode=require
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Local PostgreSQL Parameters (used if DATABASE_URL is not set)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=mrh_admin
DATABASE_PASSWORD=change_me_in_production
DATABASE_NAME=mrh_academy_db

# ==============================================================================
# 3. SECURITY, JWT & COOKIES
# ==============================================================================
# Secret key for JWT signing (Minimum 32 characters in dev, 64 in production)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_secret_of_at_least_64_characters_before_production
JWT_EXPIRES_IN=15m
JWT_ISSUER=mrh-academy-api
JWT_AUDIENCE=mrh-academy-web
COOKIE_SECURE=false

# System Passwords & Admin Accounts
ADMIN_EMAILS=admin@mrh-academy.example
REFERRAL_SECRET=
DEMO_SEED_PASSWORD=
SUBADMIN_DEFAULT_PASSWORD=

# ==============================================================================
# 4. REDIS CACHE & QUEUE
# ==============================================================================
REDIS_URL=redis://localhost:6379

# ==============================================================================
# 5. GOOGLE AUTHENTICATION & CALENDAR INTEGRATION
# ==============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_IMPERSONATE_EMAIL=

# ==============================================================================
# 6. CLOUDINARY (Media & Image Uploads)
# ==============================================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==============================================================================
# 7. BUNNY.NET (Video Hosting & Secure HLS Streaming)
# ==============================================================================
BUNNY_API_KEY=
BUNNY_READONLY_API_KEY=
BUNNY_LIBRARY_ID=
BUNNY_CDN_HOSTNAME=
# Stream library token-authentication key (for securing video embeds)
BUNNY_TOKEN_AUTH_KEY=

# ==============================================================================
# 8. AI & WEBRTC ROOM SERVICES
# ==============================================================================
GEMINI_API_KEY=
METERED_API_KEY=
METERED_APP_NAME=mrh_academy

# ==============================================================================
# 9. STRIPE PAYMENT GATEWAY
# ==============================================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal Orders API (use sandbox URL for testing and live URL in production)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ==============================================================================
# 10. EMAIL SERVICE (SMTP / Ethereal / SendGrid)
# ==============================================================================
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MRH Academy" <no-reply@mrh-academy.example>

# ==============================================================================
# 11. PDF GENERATION & SYSTEM OPTIONAL SETTINGS
# ==============================================================================
ARABIC_PDF_FONT_PATH=
CONFIRM_VALIDATE=no
