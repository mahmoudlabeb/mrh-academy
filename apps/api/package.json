{
  "name": "@mrh/api",
  "version": "0.0.0",
  "description": "Mr.H Academy NestJS API",
  "type": "commonjs",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npm run start:dev",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main.js",
    "start:dev": "node --max-old-space-size=4096 node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:seed:demo": "nest build && node dist/database/seeds/demo.seed.js",
    "migration:run": "nest build && node dist/database/run-migrations.js",
    "migration:validate": "nest build && node dist/database/validate-migrations.js",
    "migration:generate": "nest build && typeorm migration:generate -d dist/database/data-source.js",
    "db:backup": "tsx src/database/commands/backup.ts"
  },
  "dependencies": {
    "@mrh/types": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "11",
    "@nestjs/passport": "11",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "@nestjs/websockets": "^11.1.27",
    "arabic-reshaper": "^1.1.0",
    "bcrypt": "5.1.1",
    "bidi-js": "^1.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "joi": "^18.2.3",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.5",
    "socket.io": "^4.8.3",
    "stripe": "^22.3.0",
    "typeorm": "0.3.31",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/sanitize-html": "^2.16.1",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "moduleResolution": "node",
            "resolvePackageJsonExports": false
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/main.ts",
      "!**/seed.ts",
      "!**/*.module.ts",
      "!**/*.dto.ts",
      "!**/index.ts",
      "!**/entities/**",
      "!**/database/**",
      "!**/admin/**",
      "!**/migrations/**",
      "!**/courses/**",
      "!**/tutors/**",
      "!**/students/**",
      "!**/vocabulary/**",
      "!**/messages/**",
      "!**/reports/**",
      "!**/redis/**",
      "!**/shared/**",
      "!**/articles/**",
      "!**/availability/**",
      "!**/gateway/**"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "branches": 12,
        "functions": 12,
        "lines": 16,
        "statements": 18
      },
      "src/auth/auth.service.ts": {
        "branches": 60,
        "functions": 70,
        "lines": 70,
        "statements": 70
      },
      "src/lessons/lessons.service.ts": {
        "branches": 60,
        "functions": 60,
        "lines": 70,
        "statements": 70
      },
      "src/payments/payments.service.ts": {
        "branches": 40,
        "functions": 20,
        "lines": 45,
        "statements": 45
      },
      "src/services/commission.service.ts": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    },
    "testEnvironment": "node"
  }
}
