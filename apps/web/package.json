{
  "name": "@mrh/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "jest --testPathPatterns=\"src/.*\\.spec\\.ts\" --passWithNoTests",
    "test:run": "jest --testPathPatterns=\"src/.*\\.spec\\.ts\" --passWithNoTests --forceExit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "jest": {
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "moduleResolution": "node",
            "esModuleInterop": true,
            "allowJs": true,
            "strict": false,
            "paths": {
              "@/*": [
                "../src/*"
              ]
            }
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "moduleDirectories": [
      "node_modules",
      "<rootDir>"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@mrh/types": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.80.0",
    "react-markdown": "^10.1.0",
    "socket.io-client": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "jest": "^30.0.0",
    "pg": "^8.22.0",
    "postcss": "^8.5.10",
    "ts-jest": "^29.2.5",
    "typescript": "^5"
  }
}
