# =============================================================================
# MRH Academy — Production Environment Template
# =============================================================================
# Copy values into your hosting dashboards:
#   • API (Render):  https://dashboard.render.com → your API service → Environment
#   • Web (Vercel):  https://vercel.com → project → Settings → Environment Variables
#
# Do NOT commit real secrets. Fill placeholders, then verify with:
#   .\scripts\test-integrations.ps1
# =============================================================================

# ─── Server (Render API) ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://mrh-academy-1.vercel.app

# ─── Database (Render PostgreSQL or external) ───────────────────────────────
# Prefer DATABASE_URL on Render (Internal Database URL from PostgreSQL service)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Alternative if not using DATABASE_URL:
# DATABASE_HOST=
# DATABASE_PORT=5432
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=

# ─── JWT (generate: openssl rand -base64 48) ─────────────────────────────────
JWT_SECRET=REPLACE_WITH_48_PLUS_RANDOM_CHARACTERS
JWT_EXPIRES_IN=15m

# ─── Redis (Render Redis or Upstash) ─────────────────────────────────────────
REDIS_URL=redis://default:PASSWORD@HOST:6379

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Optional on API; used if frontend needs publishable key later
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=REPLACE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-REPLACE
GOOGLE_CALLBACK_URL=https://mrh-academy.onrender.com/api/v1/auth/google/callback

# ─── Cloudinary (avatars, payment screenshots, lesson books) ─────────────────
# Dashboard: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=REPLACE
CLOUDINARY_API_KEY=REPLACE
CLOUDINARY_API_SECRET=REPLACE

# ─── Bunny.net Stream (course videos) ────────────────────────────────────────
# Dashboard: https://dash.bunny.net → Stream → your Video Library
BUNNY_API_KEY=REPLACE
BUNNY_LIBRARY_ID=REPLACE
BUNNY_CDN_HOSTNAME=vz-REPLACE.b-cdn.net

# ─── Email / SMTP (SendGrid, Mailgun, Amazon SES, etc.) ──────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=SG.REPLACE_ME
SMTP_FROM=no-reply@yourdomain.com

# ─── Gemini AI (vocabulary feature) ──────────────────────────────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=REPLACE

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@mrhacademy.com
SUBADMIN_DEFAULT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── Database migrations (keep true on production deploys) ────────────────────
RUN_MIGRATIONS=true
DB_SYNCHRONIZE=false
CONFIRM_BOOTSTRAP=no

# =============================================================================
# Vercel (Web app only) — add in Vercel dashboard, then redeploy
# =============================================================================
# NEXT_PUBLIC_API_URL=https://mrh-academy.onrender.com/api/v1
