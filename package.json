{
  "name": "mrh-academy",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "db:backup": "pnpm --filter @mrh/api db:backup",
    "test:e2e": "pnpm --filter @mrh/api test:e2e"
  },
  "devDependencies": {
    "knip": "^5.46.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@11.0.0",
  "resolutions": {
    "postcss": ">=8.5.10",
    "multer": ">=2.2.0",
    "js-yaml": ">=4.2.0"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "multer": ">=2.2.0",
    "js-yaml": ">=4.2.0"
  }
}
