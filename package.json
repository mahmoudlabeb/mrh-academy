{
  "name": "mrh-academy-monorepo",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "protect": "node scripts/protect.js",
    "client-start": "cd apps/api && npm run start:prod & cd apps/web && npm run start",
    "test:api": "powershell -ExecutionPolicy Bypass -File scripts/test-api-deliverables.ps1",
    "test:deliverables": "powershell -ExecutionPolicy Bypass -File scripts/run-all-tests.ps1",
    "test:integrations": "powershell -ExecutionPolicy Bypass -File scripts/test-integrations.ps1",
    "test:e2e": "cd apps/api && pnpm test:e2e"
  },
  "devDependencies": {
    "javascript-obfuscator": "^4.1.1",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "resolutions": {
    "postcss": ">=8.5.10",
    "multer": ">=2.2.0",
    "js-yaml": ">=4.2.0"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "multer": ">=2.2.0",
    "js-yaml": ">=4.2.0"
  }
}
